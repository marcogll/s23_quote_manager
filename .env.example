# ============================================================
# Soul:23 Product Editor - Variables de Entorno
# Copiar este archivo a .env y completar los valores
# ============================================================

# ----------------------------------------------------------
# Base de datos PostgreSQL
# ----------------------------------------------------------
# Local (Docker Compose): postgresql://postgres:postgres@db:5432/soul23_products?schema=public
# Railway: asignado automaticamente al agregar el servicio PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@db:5432/soul23_products?schema=public

# Configuracion PostgreSQL (solo para docker-compose local)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=soul23_products
DB_PORT=5432

# ----------------------------------------------------------
# NextAuth.js
# ----------------------------------------------------------
# URL base de la aplicacion
NEXTAUTH_URL=http://localhost:3000

# Clave secreta para firmar tokens de sesion
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=cambia-esta-clave-por-una-segura-en-produccion

# ----------------------------------------------------------
# Puerto de la aplicacion (solo para docker-compose)
# ----------------------------------------------------------
APP_PORT=3000
