# Copia estas variables en Environment Variables > Developer View de Coolify.
# No uses estos valores de ejemplo en produccion.

# PostgreSQL del stack docker-compose.coolify.yml
POSTGRES_USER=s23
POSTGRES_PASSWORD=reemplaza-con-una-clave-larga-y-aleatoria
POSTGRES_DB=s23_quotes

# Dominio publico HTTPS asignado al servicio app
APP_URL=https://cotizaciones.example.com

# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=reemplaza-con-un-secreto-aleatorio

# Administrador inicial. Las cuatro variables pueden dejarse vacias para omitirlo.
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=reemplaza-con-una-clave-de-al-menos-8-caracteres
ADMIN_NAME=Administrador
